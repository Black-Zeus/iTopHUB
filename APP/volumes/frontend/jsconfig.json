{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@pages/*": ["src/pages/*"],
      "@routes/*": ["src/router/*"],
      "@styles/*": ["src/styles/*"],
      "@data/*": ["src/data/*"],
      "@services/*": ["src/services/*"],
      "@ui/*": ["src/ui/*"],
      "@components/*": ["src/components/*"],
      "@layout/*": ["src/layout/*"],
      "@hooks/*": ["src/hooks/*"]
    }
  },
  "include": ["src"]
}
