# Git Bash curl tests - bateria completa WorkFlow_v2
# Ejecutar desde la raiz del proyecto o cualquier consola Git Bash.
# Respuestas esperadas: positivos HTTP 202, validaciones HTTP 400, seguridad HTTP 403.

export N8N_BASE="http://localhost:8089/n8n"
export WEBHOOK_TOKEN="120cce89d60ecb6e13dbee08bbde8d3db193c29edb17e4cf08fc6f4eb7eba0a7"

call_ok() {
  local path="$1"
  local body="$2"
  curl -i -X POST "$N8N_BASE/webhook/$path" \
    -H "Content-Type: application/json" \
    -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
    --data-raw "$body"
}

call_no_token() {
  local path="$1"
  local body="$2"
  curl -i -X POST "$N8N_BASE/webhook/$path" \
    -H "Content-Type: application/json" \
    --data-raw "$body"
}

call_bad_token() {
  local path="$1"
  local body="$2"
  curl -i -X POST "$N8N_BASE/webhook/$path" \
    -H "Content-Type: application/json" \
    -H "X-Webhook-Token: token_incorrecto" \
    --data-raw "$body"
}

echo "## Seguridad global"
call_no_token "cmdb-activos-sin-contacto" '{"email_to":"usuario1@company.com"}'
call_bad_token "cmdb-activos-sin-contacto" '{"email_to":"usuario1@company.com"}'

echo "## cmdb-activos-garantia-vencida - minimo valido"
call_ok "cmdb-activos-garantia-vencida" '{"email_to":"usuario1@company.com"}'

echo "## cmdb-activos-garantia-vencida - sin adjunto"
