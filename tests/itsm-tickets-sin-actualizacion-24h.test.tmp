# Git Bash curl tests - ITSM - Tickets sin actualización mayor a 24h - SMTP
# Solo se incluyen parametros permitidos por webhook.

export PROD_WEBHOOK="http://localhost:8089/n8n/webhook/itsm-tickets-sin-actualizacion-24h"
export TEST_WEBHOOK="http://localhost:8089/n8n/webhook-test/itsm-tickets-sin-actualizacion-24h"
export WEBHOOK_TOKEN="120cce89d60ecb6e13dbee08bbde8d3db193c29edb17e4cf08fc6f4eb7eba0a7"

# Error / seguridad
# Sin token: debe responder HTTP 403.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  --data-raw '{}'

# Token incorrecto: debe responder HTTP 403.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: token_incorrecto" \
  --data-raw '{}'

# Exito: debe responder HTTP 202 y continuar la ejecucion del flujo.
# Body minimo valido: email_to es obligatorio en llamadas webhook; el resto usa defaults locales.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","stale_threshold_hours":24}'

# Error funcional: con token valido, pero sin email_to, debe responder HTTP 400 y cortar el flujo.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{}'

# Error funcional: falta stale_threshold_hours requerido para este flujo.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com"}'

# Destinatarios explicitos.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","email_cc":"supervisor@company.com","email_bcc":"auditoria@company.com","stale_threshold_hours":24}'

# Sin adjunto.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","include_attachment":false,"stale_threshold_hours":24}'

# Solo resumen.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","include_summary":true,"include_detail":false,"include_attachment":false,"stale_threshold_hours":24}'

# Sin notas y sin boton iTop.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","include_operational_notes":false,"include_itop_button_footer":false,"stale_threshold_hours":24}'

# Ventana de fechas.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","start_date":"2026-05-01 00:00:00","end_date":"2026-05-08 23:59:59","stale_threshold_hours":24}'

# Umbral sin actualizacion.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","stale_threshold_hours":48}'

# Filtro ITSM.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","include_requirements":true,"include_incidents":true,"include_changes":false,"include_problems":false,"stale_threshold_hours":24}'

# Todas las variables PUBLICAS permitidas por webhook.
curl -i -X POST "$PROD_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","email_cc":"supervisor@company.com","email_bcc":"auditoria@company.com","stale_threshold_hours":24,"include_requirements":true,"include_incidents":true,"include_changes":true,"include_problems":true,"include_attachment":true,"include_detail":true,"include_summary":true,"include_operational_notes":true,"include_itop_button_footer":true,"start_date":"2026-05-01 00:00:00","end_date":"2026-05-08 23:59:59"}'

# Webhook test. Antes presiona "Listen for test event".
curl -i -X POST "$TEST_WEBHOOK" \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Token: $WEBHOOK_TOKEN" \
  --data-raw '{"email_to":"usuario1@company.com","include_attachment":false,"stale_threshold_hours":24}'

