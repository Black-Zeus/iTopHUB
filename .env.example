PROJECT_NAME=itophub
TZ=America/Argentina/San_Juan

# Variables base comunes a todos los entornos.
# Los archivos .env.dev / .env.qa / .env.prd solo deben sobreescribir
# las variables que cambian por ambiente.

VOLUMES_ROOT=./APP/volumes
SETTINGS_ROOT=./APP/config

MARIADB_ROOT_PASSWORD=change_me_root
MARIADB_USER=itophub_user
MARIADB_PASSWORD=change_me_db
MARIADB_PORT=3306
APP_DB_NAME=itophub_app
ITOP_DB_NAME=itophub_itop

REDIS_DB=0
REDIS_PORT=6379
REDISINSIGHT_PORT=5540

ITOP_PHP_BASE_IMAGE=php:8.2-apache-bookworm
ITOP_ADMIN_USER=admin
ITOP_ADMIN_PASSWORD=admin
ITOP_URL=http://localhost
ITOP_REST_USER=
ITOP_REST_PASSWORD=
ITOP_AUTH_TOKEN=
ITOP_VERIFY_SSL=1
ITOP_TIMEOUT_SECONDS=30
HUB_TOKEN_KEK=change_me_hub_token_kek
HUB_TOKEN_KEK_VERSION=v1
HUB_SESSION_TTL_SECONDS=14400
HUB_RUNTIME_TOKEN_TTL_SECONDS=3600
HUB_SESSION_WARNING_SECONDS=30
PDQ_ENABLED=1
PDQ_SQLITE_DIR=/app/data/pdq
PDQ_SQLITE_FILE_NAME=
PDQ_SQLITE_FILE_GLOB=*.db;*.sqlite;*.sqlite3
PDQ_SEARCH_MIN_CHARS=2
ITOP_PACKAGE_VERSION=3.2.2-1
ITOP_PACKAGE_URL=
ITOP_INSTALL_FORCE=0
ITOP_AUTO_INSTALL_IF_EMPTY=1

REDISINSIGHT_IMAGE=redis/redisinsight:2.54

VITE_APP_NAME=iTop Hub

SMTP_FROM_EMAIL=no-reply@itophub.local
SMTP_HOST=mailpit
SMTP_PORT=1025

PDF_WORKER_QUEUE=pdf_jobs
PDF_WORKER_URL=http://pdf-worker:8000
WORKER_HEARTBEAT_SECONDS=300
PDF_WORKER_HEARTBEAT_SECONDS=300
INTERNAL_API_SECRET=change_me_internal_secret
JWT_SECRET=change_me_jwt_secret
